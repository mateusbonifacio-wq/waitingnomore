{
  "manifest_version": 3,
  "name": "Keel",
  "version": "1.0.23",
  "description": "Keel is what keeps you steady when you start to drift. Calm overlay while ChatGPT or Gemini generates.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Before you drift."
  },
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "http://localhost:*/*",
      "https://localhost:*/*",
      "http://127.0.0.1:*/*",
      "https://127.0.0.1:*/*",
      "https://*.vercel.app/*"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": [
        "sites/chatgpt-generation.js",
        "games/registry.js",
        "games/play-pace.js",
        "games/current.js",
        "games/keep-alive.js",
        "games/quick-pattern.js",
        "games/micro-memory.js",
        "games/create-micro-game.js",
        "brain/questions.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "sites/gemini-generation.js",
        "games/registry.js",
        "games/play-pace.js",
        "games/current.js",
        "games/keep-alive.js",
        "games/quick-pattern.js",
        "games/micro-memory.js",
        "games/create-micro-game.js",
        "brain/questions.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://localhost:*/*",
        "https://localhost:*/*",
        "http://127.0.0.1:*/*",
        "https://127.0.0.1:*/*",
        "https://*.vercel.app/*"
      ],
      "js": ["webBridge.js"],
      "run_at": "document_idle"
    }
  ]
}
