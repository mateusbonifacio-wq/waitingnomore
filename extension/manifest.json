{
  "manifest_version": 3,
  "name": "Keel",
  "version": "1.0.13",
  "description": "Keel is what keeps you steady when you start to drift. A calm overlay for ChatGPT while it generates.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Before you drift."
  },
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*",
      "https://*.vercel.app/*"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}
