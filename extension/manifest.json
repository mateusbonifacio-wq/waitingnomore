{
  "manifest_version": 3,
  "name": "Keel",
  "version": "1.0.39",
  "description": "Keel is what keeps you steady when you start to drift. Calm overlay while ChatGPT, Claude, or Gemini generates.",
  "homepage_url": "https://waitingnomore.vercel.app",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Before you drift."
  },
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "https://waitingnomore.vercel.app/*"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": [
        "sites/chatgpt-generation.js",
        "games/registry.js",
        "games/play-pace.js",
        "games/current.js",
        "games/keep-alive.js",
        "games/quick-pattern.js",
        "games/micro-memory.js",
        "games/create-micro-game.js",
        "brain/questions.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "sites/gemini-generation.js",
        "games/registry.js",
        "games/play-pace.js",
        "games/current.js",
        "games/keep-alive.js",
        "games/quick-pattern.js",
        "games/micro-memory.js",
        "games/create-micro-game.js",
        "brain/questions.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://claude.ai/*", "https://www.claude.ai/*"],
      "all_frames": true,
      "js": [
        "sites/claude-generation.js",
        "games/registry.js",
        "games/play-pace.js",
        "games/current.js",
        "games/keep-alive.js",
        "games/quick-pattern.js",
        "games/micro-memory.js",
        "games/create-micro-game.js",
        "brain/questions.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://waitingnomore.vercel.app/*"
      ],
      "js": ["webBridge.js"],
      "run_at": "document_idle"
    }
  ]
}
