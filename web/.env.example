# Optional: Chrome extension ID for custom production domains not listed in extension manifest webBridge matches.
# Local testing and *.vercel.app use the in-page bridge — this is usually empty.
NEXT_PUBLIC_EXTENSION_ID=

# Supabase project URL and anon public key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
