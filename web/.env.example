# Optional: Chrome extension ID for custom production domains not listed in extension manifest webBridge matches.
# Local testing and *.vercel.app use the in-page bridge — this is usually empty.
NEXT_PUBLIC_EXTENSION_ID=

# Supabase project URL + public API key (Settings → API in Supabase).
NEXT_PUBLIC_SUPABASE_URL=
# Use either name — same value as "anon" or "publishable default" in the Supabase UI.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
