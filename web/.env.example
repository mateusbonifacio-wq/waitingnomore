# Optional: Chrome extension ID for custom production domains not listed in extension manifest webBridge matches.
# Local testing and *.vercel.app use the in-page bridge — this is usually empty.
NEXT_PUBLIC_EXTENSION_ID=

# Supabase project URL + public API key (Settings → API in Supabase).
NEXT_PUBLIC_SUPABASE_URL=
# Use either name — same value as "anon" or "publishable default" in the Supabase UI.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Auth (configure in Supabase Dashboard → Authentication → Providers → Email):
# - Enable "Email" provider. Keel uses email + password as the default path; magic link remains optional.
# - If no confirmation (or magic-link) email arrives: the app only calls Supabase; delivery is from YOUR Supabase
#   project. Check spam; Authentication → Logs for send errors; built-in mailer is rate-limited — configure SMTP:
#   https://supabase.com/docs/guides/auth/auth-smtp (Project Settings → Authentication → SMTP Settings).
#   The login UI includes “Resend confirmation email” after sign-up without a session.
# - For local/dev without inbox friction: disable “Confirm email” (same Email provider screen) so sign-up returns
#   a session immediately. Re-enable for production if you want one-time email verification.
# - URL config: Authentication → URL Configuration — set Site URL to your app (e.g. http://localhost:3000) and add
#   redirect URLs so confirmation links work.
# - Session length: Authentication → Sessions — defaults work with @supabase/ssr cookie storage (persistent across reloads).
